# =============================================================================
# Buzzerator secrets — Home Assistant
# Copy this file to secrets.yaml and fill in the REPLACE_ME values.
# Path (HA container): /config/secrets.yaml
# NEVER commit secrets.yaml to git — add it to .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# ORCHESTRATOR ONLY — not read by HA YAML (!secret)
# Used by implementation agents for REST API / UI automation during setup.
# Generate: HA Profile → Security → Long-Lived Access Tokens → Create Token
# -----------------------------------------------------------------------------
ha_long_lived_access_token: "REPLACE_ME"

# -----------------------------------------------------------------------------
# ANTHROPIC — enter the SAME key in HA UI when adding the Anthropic integration
# Settings → Devices & Services → Add Integration → Anthropic
# Also kept here for your reference and some plan steps.
# Generate: https://console.anthropic.com/keys
# -----------------------------------------------------------------------------
anthropic_api_key: "REPLACE_ME"

# -----------------------------------------------------------------------------
# CONVERSATION AGENT IDs — fill AFTER creating agents in HA UI
# Settings → Voice Assistants → Conversation Agents
# Copy exact entity_id from each agent (may differ slightly from examples).
# Used by Telegram automation: !secret claude_telegram_router_agent_id
# -----------------------------------------------------------------------------
claude_task_manager_agent_id: "conversation.claude_task_manager"
claude_telegram_router_agent_id: "conversation.claude_telegram_router"

# -----------------------------------------------------------------------------
# TELEGRAM — configure bot and chat IDs
# Bot token: @BotFather → /newbot
# Chat IDs: @userinfobot (integers, NO quotes on the numbers)
# Second user optional — delete line or use 0 if single-user household
# -----------------------------------------------------------------------------
telegram_api_token: "REPLACE_ME"
telegram_chat_id_user1: REPLACE_ME
telegram_chat_id_user2: 0  # Optional: set to 0 to disable second user
